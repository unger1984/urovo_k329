#!/usr/bin/env python3
"""
CUPS backend для Urovo K329.
Сохраняет PDF в spool-папку. Launchd daemon подхватывает и печатает.
"""

import sys
import os
import logging

logging.basicConfig(
    level=logging.DEBUG,
    format="urovo329: %(message)s",
    stream=sys.stderr,
)
log = logging.getLogger(__name__)

SPOOL_DIR = "/var/spool/urovo329"


def list_devices():
    print('direct urovo329://USB "Urovo K329" "Urovo K329 TSPL2 Label Printer"')
    sys.exit(0)


def main():
    if len(sys.argv) == 1:
        list_devices()
        return

    if len(sys.argv) < 6:
        sys.exit(1)

    job_id = sys.argv[1]
    user = sys.argv[2]
    title = sys.argv[3]
    copies = int(sys.argv[4])
    options = sys.argv[5]
    input_file = sys.argv[6] if len(sys.argv) > 6 else None

    log.info("Job %s: user=%s title=%s copies=%d", job_id, user, title, copies)

    # Читаем PDF
    if input_file:
        with open(input_file, "rb") as f:
            data = f.read()
    else:
        data = sys.stdin.buffer.read()

    # Сохраняем в spool
    pdf_path = os.path.join(SPOOL_DIR, f"job-{job_id}.pdf")
    copies_path = os.path.join(SPOOL_DIR, f"job-{job_id}.copies")

    with open(pdf_path, "wb") as f:
        f.write(data)

    with open(copies_path, "w") as f:
        f.write(str(copies))

    log.info("Saved %s (%d bytes, %d copies)", pdf_path, len(data), copies)

    # Ждём пока helper обработает (launchd запустит по WatchPaths)
    # Максимум 60 секунд
    for _ in range(120):
        if not os.path.exists(pdf_path):
            log.info("Job %s напечатан", job_id)
            return
        import time
        time.sleep(0.5)

    log.error("Timeout: helper не обработал задание")
    # Удаляем чтобы не зависло
    try:
        os.unlink(pdf_path)
        os.unlink(copies_path)
    except OSError:
        pass
    sys.exit(1)


if __name__ == "__main__":
    main()
